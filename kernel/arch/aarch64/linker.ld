ENTRY(kernel_entry)

SECTIONS
{
  . = 0x40200000;
  __kernel_start = .;

  .text : ALIGN(0x1000) {
    __text_start = .;
    *(.text.entry)
    *(.text.secondary)
    *(.text.vectors)
    *(.text .text.*)
    __text_end = .;
    . = ALIGN(0x1000);
    __user_text_start = .;
    *(.user.text)
    __user_text_end = .;
  }

  .rodata : ALIGN(0x1000) {
    __rodata_start = .;
    *(.rodata .rodata.*)
    __rodata_end = .;
    . = ALIGN(0x1000);
    __user_rodata_start = .;
    *(.user.rodata)
    __user_rodata_end = .;
  }

  .data : ALIGN(0x1000) {
    __data_start = .;
    *(.data .data.*)
    __data_end = .;
  }

  .bss : ALIGN(0x1000) {
    __bss_start = .;
    *(.bss .bss.* COMMON)
    __bss_end = .;
    . = ALIGN(0x1000);
    __user_stack_start = .;
    *(.user.stack)
    __user_stack_end = .;
  }

  . = ALIGN(0x1000);
  __kernel_end = .;
}

/* Assert kernel fits within 2 MB for QEMU flash compatibility */
ASSERT(__kernel_end - __kernel_start < 2M, "Kernel too large (max 2 MB)")
