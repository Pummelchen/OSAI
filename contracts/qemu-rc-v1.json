      "service_manager",
      "service_descriptor",
      "mode",
      "child_service",
      "child_parent",
      "child_restart"
    ]
  },
  "cpu_ai_model_format": {
    "name": "OSAI QEMU CPU-AI model image",
    "magic": "OSAI_MODEL_MIAI",
    "magic_value": "0x4941494d",
    "version": 1,
    "header_bytes": 80,
    "path": "/models/cpu-ai-mvp.osaimodel",
    "quantization": 8,
    "tokenizer": "byte table",
    "tokenizer_bytes": 256,
    "runtime": "deterministic CPU dispatch",
    "checksum": "fnv1a64 over weight bytes followed by tokenizer bytes",
    "cpu_only_required": true,
    "gpu_required_rejected": true,
    "private_kv_required": true,
    "shared_weights_read_only": true
  },
  "ai_cell_descriptor_abi": {
    "name": "OSAI AI Cell descriptor ABI",
    "magic": "AIC1",
    "magic_value": "0x41494331",
    "version": 1,
    "descriptor_bytes": 112,
    "checksum": "fnv1a64 over descriptor bytes with checksum field zeroed",
    "required_flags": [
      "cpu_only",
      "fixed_cores",
      "shared_model",
      "private_kv",
      "nic_queue",
      "git_workspace"
    ],
    "resource_contract": [
      "exclusive core lease",
      "shared read-only model arena",
      "private KV/cache arena",
      "private source-index arena",
      "private build-output arena",
      "private log arena",
      "exclusive NIC queue binding",
      "exclusive Git workspace binding"
    ],
    "admission_failures": [
      "bad checksum",
      "bad version",
      "missing required flags",
      "missing model arena",
      "duplicate core lease",
      "duplicate NIC queue",
      "duplicate Git workspace"
    ]
  },
  "persistence_format": {
    "name": "OSAI QEMU mutable state sector",
    "magic": "OSAIPST1",
    "version": 1,
    "sector": 1536,
    "sector_bytes": 512,
    "max_snapshots": 8,
    "label_max": 32,
    "checksum": "fnv1a64 over sector with checksum field zeroed",
    "snapshot_kinds": [
      "boot_config",
      "service",
      "workspace",
      "sandbox",
      "update"
    ]
  },
  "service_descriptor_format": {
    "name": "OSAI service descriptor",
    "encoding": "ascii key=value lines",
    "path": "/etc/services/source-index.svc",
    "required_keys": ["name", "parent", "restart", "start", "status"],
    "expected_values": {
      "name": "/svc/source-index",
      "parent": "/init",
      "restart": "never",
      "start": "true",
      "status": "true"
    }
  },
  "security_policy": {
    "name": "OSAI QEMU security hardening policy",
