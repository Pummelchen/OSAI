  "filesystem_format": {
    "name": "OSAI read-only initramfs",
    "magic": "OSAIROFS2",
    "version": 2,
    "header_sector": 1,
    "sector_size": 512,
    "header_bytes": 512,
    "block_size": 512,
    "max_files": 4,
    "path_max": 64,
    "data_offset": 4096,
    "flags": ["read_only"],
    "entry_type": "file",
    "entry_flags": ["executable", "manifest"],
    "required_paths": [
      "/init",
      "/bin/service-manager",
      "/etc/osai-init.conf",
      "/etc/services/source-index.svc"
    ],
    "manifest_path": "/etc/osai-init.conf",
    "manifest_keys": [
      "service",
      "service_manager",
      "service_descriptor",
      "mode",
      "child_service",
      "child_parent",
      "child_restart"
    ]
  },
  "persistence_format": {
    "name": "OSAI QEMU mutable state sector",
    "magic": "OSAIPST1",
    "version": 1,
    "sector": 1536,
    "sector_bytes": 512,
    "max_snapshots": 8,
    "label_max": 32,
    "checksum": "fnv1a64 over sector with checksum field zeroed",
    "snapshot_kinds": [
      "boot_config",
      "service",
      "workspace",
      "sandbox",
      "update"
    ]
  },
  "service_descriptor_format": {
    "name": "OSAI service descriptor",
    "encoding": "ascii key=value lines",
    "path": "/etc/services/source-index.svc",
    "required_keys": ["name", "parent", "restart", "start", "status"],
    "expected_values": {
      "name": "/svc/source-index",
      "parent": "/init",
      "restart": "never",
      "start": "true",
      "status": "true"
    }
  },
