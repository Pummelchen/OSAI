  "filesystem_format": {
    "name": "OSAI read-only initramfs",
    "magic": "OSAIROFS2",
    "version": 2,
    "header_sector": 1,
    "sector_size": 512,
    "header_bytes": 1024,
    "block_size": 512,
    "max_files": 5,
    "path_max": 64,
    "data_offset": 4096,
    "flags": ["read_only"],
    "entry_type": "file",
    "entry_flags": ["executable", "manifest"],
    "required_paths": [
      "/init",
      "/bin/service-manager",
      "/etc/osai-init.conf",
      "/etc/services/source-index.svc",
      "/models/cpu-ai-mvp.osaimodel"
    ],
    "manifest_path": "/etc/osai-init.conf",
    "manifest_keys": [
